+<body>
+    <h1>🎵 Playlist Generator <span class="pulse">:: ONLINE</span></h1>
+
+    <button onclick="generatePlaylist()">⚡ GENERATE FREQUENCY MATRIX</button>
+
+    <div class="card" id="playlistCard" style="display:none;">
+        <span class="data-label">Atmospheric Mood</span>
+        <span class="data-value" id="mood"></span>
+
+        <span class="data-label">Spotify Playlist</span>
