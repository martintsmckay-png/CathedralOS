+        button {
+            background: transparent;
+            color: var(--matrix-glow);
+            border: 1px solid var(--matrix-glow);
+            padding: 15px;
+            cursor: pointer;
+            font-family: inherit;
+            font-weight: bold;
+            width: 100%;
+            margin-top: 20px;
+            font-size: 1.2em;
+            transition: 0.2s;
+        }
+        button:hover { 
+            background: var(--matrix-glow); 
+            color: var(--matrix-bg); 
+        }
+        
+        .track-list {
+            margin-top: 15px;
+            border-left: 2px solid var(--matrix-glow);
