+        .empty-state span {
+            font-size: 3em;
+            display: block;
+            margin-bottom: 15px;
+        }
+
+        .footer-note {
+            color: #666;
+            font-size: 0.8em;
+            margin-top: 10px;
+        }
+    </style>
+</head>
+<body>
+    <svg class="heartbeat-bg" viewBox="0 0 1200 800" preserveAspectRatio="none" aria-hidden="true">
+        <path class="heartbeat-line" d="M0 420 L180 420 L240 420 L270 340 L300 520 L340 420 L520 420 L560 400 L600 460 L650 220 L700 620 L760 420 L980 420 L1040 420 L1080 360 L1120 500 L1160 420 L1200 420" />
+    </svg>
+
+    <div class="pantry-shell">
+        <h1>📦 Memory Pantry <span class="pulse" style="color:var(--caramel)">:: PRESERVED</span></h1>
+
+        <div class="card">
+            <span class="data-label">Store New Memory</span>
+            <div class="input-group">
+                <input type="text" id="memoryTitle" placeholder="Title (e.g., Forgotten Tuesday)">
+                <button onclick="storeMemory()">💾 SAVE</button>
+            </div>
+            <input type="text" id="memoryContent" placeholder="Content (blessings, quest rewards, caramel residue...)" style="width: 100%; margin-top: 10px;">
+            <div class="footer-note">Long entries will wrap and scroll inside each memory card.</div>
+        </div>
+
+        <div class="card">
+            <span class="data-label">Memory Inventory</span>
+            <span class="data-value" id="memoryCount">0 items preserved</span>
+            <div class="memory-list" id="memoryList">
+                <div class="empty-state">
+                    <span>🍮</span>
+                    The pantry is empty.<br>
+                    Add your first caramel of remembrance.
+                </div>
+            </div>
+        </div>
+    </div>
+
+    <script>
+        let memories = [];
+
+        function loadMemories() {
+            try {
+                const stored = localStorage.getItem('cathedralos_memories');
+                if (stored) memories = JSON.parse(stored);
+            } catch (e) {
+                memories = [];
+            }
+            renderMemories();
+        }
+
+        function storeMemory() {
+            const titleInput = document.getElementById('memoryTitle');
+            const contentInput = document.getElementById('memoryContent');
+
+            const title = titleInput.value.trim();
+            const content = contentInput.value.trim();
+
+            if (!title || !content) {
+                alert('🍮 Title and content required. The pantry rejects empty vessels.');
+                return;
+            }
+
+            memories.unshift({
+                id: Date.now(),
+                title,
+                content,
+                date: new Date().toISOString()
+            });
+
+            saveMemories();
+            titleInput.value = '';
+            contentInput.value = '';
+            alert('🍮 Memory preserved. Caramel sealed.');
+        }
+
+        function deleteMemory(id) {
+            if (confirm('🗑️ Release this memory from the pantry?')) {
+                memories = memories.filter(m => m.id !== id);
+                saveMemories();
+            }
+        }
+
+        function saveMemories() {
+            try {
+                localStorage.setItem('cathedralos_memories', JSON.stringify(memories));
+            } catch (e) {
+                alert('❌ Pantry storage failed. Memory evaporated.');
+            }
+            renderMemories();
+        }
+
+        function renderMemories() {
+            const list = document.getElementById('memoryList');
+            const count = document.getElementById('memoryCount');
+            count.innerText = `${memories.length} items preserved`;
+
+            if (memories.length === 0) {
+                list.innerHTML = `
+                    <div class="empty-state">
+                        <span>🍮</span>
+                        The pantry is empty.<br>
+                        Add your first caramel of remembrance.
+                    </div>
+                `;
+                return;
+            }
+
+            list.innerHTML = memories.map(m => {
+                const date = new Date(m.date).toLocaleString('en-US', {
+                    dateStyle: 'medium',
+                    timeStyle: 'short'
+                });
+
+                return `
+                    <div class="memory-item">
+                        <div class="memory-title">${escapeHtml(m.title)}</div>
+                        <div class="memory-content">${escapeHtml(m.content)}</div>
+                        <div class="memory-date">${date}</div>
+                        <button class="memory-delete" onclick="deleteMemory(${m.id})">🗑️ RELEASE</button>
+                    </div>
+                `;
+            }).join('');
+        }
+
+        function escapeHtml(str) {
+            return str
+                .replaceAll('&', '&amp;')
+                .replaceAll('<', '&lt;')
+                .replaceAll('>', '&gt;')
+                .replaceAll('"', '&quot;')
+                .replaceAll("'", '&#39;');
+        }
+
+        loadMemories();
+    </script>
+</body>
+</html>
