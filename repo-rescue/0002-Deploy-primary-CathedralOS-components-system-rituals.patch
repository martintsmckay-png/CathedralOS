+        
+        .card {
+            background: rgba(255, 138, 0, 0.05);
+            border: 1px solid var(--matrix-glow);
+            padding: 20px;
+            margin-top: 20px;
+            box-shadow: inset 0 0 15px rgba(255, 138, 0, 0.1);
